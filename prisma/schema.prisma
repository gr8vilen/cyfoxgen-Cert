generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Certificate {
  id        String   @id @default(cuid())
  title     String
  issuedTo  String
  createdAt DateTime @default(now())
}

model Type1Cert {
  id          String   @id @default(cuid())
  slug        String   @unique
  imageData   String   // base64-encoded image
  imageMime   String   // e.g. "image/png"
  createdAt   DateTime @default(now())
}
